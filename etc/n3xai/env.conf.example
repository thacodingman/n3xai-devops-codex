# Copy this file to /etc/n3xai/env.conf and set real values.
# Do not commit production credentials.

POSTGRE_HOST=localhost
POSTGRE_NAME=n3xai_db
POSTGRE_USER=n3xai_db_user
POSTGRE_PASS=CHANGE_ME_DB_PASSWORD

TIMEZONE=America/New_York
LANGUAGE=en_CA.UTF-8

VPS_USER=root

ADMIN1_USER=n3xaiadmin1
ADMIN1_PASS=CHANGE_ME_ADMIN1_PASSWORD
ADMIN1_EMAIL=admin1@example.com

ADMIN2_USER=n3xaiadmin2
ADMIN2_PASS=CHANGE_ME_ADMIN2_PASSWORD
ADMIN2_EMAIL=admin2@example.com

export MCP_HOME=/root/mcp
export MCP_VENV=/root/mcp/venv
export PATH=$MCP_VENV/bin:$PATH
